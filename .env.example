# Copy this to .env and fill in your values

# PostgreSQL
DATABASE_URL=postgresql://arena:arena@localhost:5432/arena01

# LLM defaults (used when no DB config is selected)
# API key (not needed for local providers like Ollama)
LLM_API_KEY=sk-...

# Base URL — change this for non-OpenAI providers:
#   OpenAI:    https://api.openai.com/v1 (default)
#   Ollama:    http://localhost:11434/v1
#   LM Studio: http://localhost:1234/v1
#   Groq:      https://api.groq.com/openai/v1
#   Together:  https://api.together.xyz/v1
LLM_BASE_URL=https://api.openai.com/v1

# Optional: default model name (overrides default gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini

{
  "name": "arena01",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "battle:mock": "tsx src/index.ts --mode mock --delay 800",
    "battle:llm": "tsx src/index.ts --mode llm",
    "battle:mixed": "tsx src/index.ts --mode mixed",
    "test": "tsx src/index.ts --mode mock --delay 0 --max-turns 10 --quiet",
    "dev:db": "docker compose up -d db && docker compose exec db sh -c 'until pg_isready -U arena -d arena01; do sleep 1; done'",
    "dev:server": "tsx src/server.ts",
    "dev:client": "vite web/",
    "dev": "npm run dev:db && concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "build:web": "vite build web/",
    "web": "npm run build:web && NODE_ENV=production tsx src/server.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@sinclair/typebox": "^0.34.49",
    "canvas": "^3.2.3",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "gif-encoder-2": "^1.0.5",
    "pg": "^8.20.0",
    "vue": "^3.5.31",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
